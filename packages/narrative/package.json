{
  "name": "@auto-engineer/narrative",
  "type": "module",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./schema": {
      "types": "./dist/src/schema.d.ts",
      "import": "./dist/src/schema.js"
    },
    "./node": {
      "types": "./dist/src/node.d.ts",
      "import": "./dist/src/node.js"
    }
  },
  "dependencies": {
    "@auto-engineer/file-store": "workspace:*",
    "@auto-engineer/id": "workspace:*",
    "@auto-engineer/message-bus": "workspace:*",
    "debug": "^4.4.1",
    "fast-glob": "^3.3.3",
    "graphql": "^16.11.0",
    "graphql-tag": "^2.12.6",
    "js-sha256": "^0.11.1",
    "prettier": "^3.6.1",
    "typescript": "^5.9.2",
    "zod": "^3.22.4",
    "zod-to-json-schema": "^3.22.3"
  },
  "scripts": {
    "build": "tsx scripts/build.ts",
    "test": "vitest run --reporter=dot",
    "test:coverage": "vitest run --reporter=dot --coverage --coverage.reporter=text",
    "type-check": "tsc --noEmit",
    "convert-narrative": "tsx scripts/convert-narrative.ts",
    "link:dev": "pnpm build && pnpm link --global",
    "unlink:dev": "pnpm unlink --global",
    "release": "pnpm publish --no-git-checks"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "fake-indexeddb": "^6.0.0",
    "tsx": "^4.20.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "version": "1.157.0"
}
