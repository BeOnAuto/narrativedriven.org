{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["build"]
    },
    "type-check": {
      "dependsOn": ["^build"]
    },
    "release": {
      "dependsOn": ["build"],
      "cache": false,
      "passThroughEnv": ["NODE_AUTH_TOKEN", "NPM_TOKEN"]
    }
  }
}
